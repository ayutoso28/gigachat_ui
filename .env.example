# URL GigaChat OAuth-сервиса. В dev по умолчанию резолвится через Vite-proxy
# (/ngw), в проде — через serverless-прокси Vercel (/ngw → /api/ngw).
# Переопределять нужно только при смене окружения (например, внутренний
# контур или свой прокси).
VITE_GIGACHAT_AUTH_URL=/ngw/api/v2/oauth

# Базовый URL API чат-комплишенов. Аналогично: dev → Vite-proxy,
# прод → Vercel rewrite → /api/giga → https://gigachat.devices.sberbank.ru.
VITE_GIGACHAT_API_URL=/giga/api/v1

# ВАЖНО: на Vercel в настройках проекта (Settings → Environment Variables)
# нужно задать NODE_TLS_REJECT_UNAUTHORIZED=0 — GigaChat использует
# корневой сертификат Минцифры, которого нет в стандартном CA-bundle
# Node.js. Переменная применяется только к serverless-функциям в /api/*
# и не влияет на фронтенд.
#
# Authorization Key и scope пользователь вводит в форме входа; в .env
# ничего класть не нужно — секрет не должен попадать в бандл.
