# URL GigaChat OAuth-сервиса. По умолчанию резолвится через прокси
# (в dev — Vite server.proxy, в проде — serverless-функция api/ngw.ts).
# Переопределять нужно только при смене окружения.
VITE_GIGACHAT_AUTH_URL=/api/ngw?path=/v2/oauth

# Базовый URL прокси чат-комплишенов. Клиент подставляет сюда
# ?path=/v1/chat/completions и т.п. Dev → Vite-proxy; прод →
# serverless-функция api/giga.ts → https://gigachat.devices.sberbank.ru.
VITE_GIGACHAT_API_URL=/api/giga

# ВАЖНО: NODE_TLS_REJECT_UNAUTHORIZED=0 устанавливается на уровне
# модуля прокси-функций в api/*.ts — GigaChat использует корневой
# сертификат Минцифры, которого нет в CA-bundle Node. Влияет только
# на serverless-функции /api/*, не на фронтенд.
#
# Authorization Key и scope пользователь вводит в форме входа; в .env
# ничего класть не нужно — секрет не должен попадать в бандл.
